{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "typeRoots": ["./node_modules/@types", "./src/types"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}